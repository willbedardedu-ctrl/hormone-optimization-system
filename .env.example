# Postgres connection string. Locally, point this at a Postgres database you control.
# In production (e.g. Vercel Postgres, Supabase, Railway, Neon) use the connection
# string your provider gives you.
DATABASE_URL="postgresql://user:password@localhost:5432/hormone_optimization?schema=public"

# Random secret used to sign login sessions. Generate one with:
#   openssl rand -base64 32
AUTH_SECRET="replace-with-a-long-random-string"

# The URL your app is served from.
NEXTAUTH_URL="http://localhost:3000"
NEXT_PUBLIC_BASE_URL="http://localhost:3000"

# From the Stripe Dashboard (Developers > API keys). Use test keys while developing.
STRIPE_SECRET_KEY=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# The Price ID (starts with price_) for your monthly membership product in Stripe.
STRIPE_PRICE_ID=""

# From the Stripe Dashboard (Developers > Webhooks) once you add an endpoint
# pointing at /api/stripe/webhook, or from `stripe listen` locally.
STRIPE_WEBHOOK_SECRET=""
